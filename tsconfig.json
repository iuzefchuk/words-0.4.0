{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "nodenext",
    "paths": { "@/*": ["./src/*"], "$/*": ["./tests/*"] },
    "types": ["vue", "vitest/globals"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "tests", "vite.config.ts", "playwright.config.ts"]
}
